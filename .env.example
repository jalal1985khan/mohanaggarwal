# Free Stock Image API Keys (Optional)
# The app works without these keys using curated fallback images
# Add your own API keys to access more diverse image collections

# Pixabay API Key
# Get your free API key from: https://pixabay.com/api/docs/
VITE_PIXABAY_API_KEY=your_pixabay_api_key_here

# Pexels API Key
# Get your free API key from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# Unsplash API Key
# Get your free API key from: https://unsplash.com/developers
VITE_UNSPLASH_API_KEY=your_unsplash_api_key_here
